# ─── Postgres ──────────────────────────────────────────────────────────
PG_USER=macro
PG_PASSWORD=changeme_local_only
PG_DB=macro
PG_PORT=5432

# Tuning — defaults assume ~8GB available (WSL2 dev).
# On Oracle ARM 24GB box, raise to: 4GB / 16MB / 512MB / 8GB
PG_SHARED_BUFFERS=256MB
PG_WORK_MEM=8MB
PG_MAINTENANCE_WORK_MEM=128MB
PG_EFFECTIVE_CACHE=1GB

# ─── App connection URLs (consumed by app/worker) ─────────────────────
DATABASE_URL=postgresql+asyncpg://macro:changeme_local_only@postgres:5432/macro
SYNC_DATABASE_URL=postgresql://macro:changeme_local_only@postgres:5432/macro
REDIS_URL=redis://redis:6379/0

# ─── API ──────────────────────────────────────────────────────────────
API_PORT=8000

# ─── External APIs (filled in as ingestors land — empty OK for D1) ───
POLYGON_API_KEY=
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# ─── Telegram (optional for D1, required by D14) ──────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── SEC EDGAR (8-K scraper) ──────────────────────────────────────────
# SEC requires a User-Agent identifying the requester for compliance.
# Use your own email or company contact.
SEC_USER_AGENT="MACRO Strategy macro-strategy@example.com"

# ─── Misc ─────────────────────────────────────────────────────────────
TZ=UTC
LOG_LEVEL=INFO
